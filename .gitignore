# ==========================================
# Unity - Carpetas de Trabajo Generales y Locales
# ==========================================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Uu]ser[Ss]ettings/
/MemoryCaptures/
/Logs/
/[Pp]ackages/manifest.json.lock

# Reglas específicas para tu subcarpeta "My project"
/My project/[Ll]ibrary/
/My project/[Tt]emp/
/My project/[Oo]bj/
/My project/[Uu]ser[Ss]ettings/
/My project/Logs/

# ==========================================
# Exclusiones de Arte y Elementos Pesados (Personalizado)
# ==========================================
# Ignora la carpeta completa de Environment (Se respaldará en ZIP)
/My project/Assets/Art/Environment/
# Excluye la malla del mapa local pesada
/My project/Assets/Art/Environment/Map/

# ==========================================
# IDEs y Editores de Código (VS, VSCode, Rider)
